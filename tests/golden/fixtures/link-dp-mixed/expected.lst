[DP]
    $00..$01: scratch_a
    $02..$03: scratch_b
    $04..$06: ptr_b


[obj#0 default]
(empty)


[obj#1 default]
000400: C2 30 B2 00 92 02 A7 04 60


[disasm obj#1 default::main]
