[default]
000000: E2 30 64 11 64 10 A9 01 48 A9 00 85 12 AA 60


[disasm obj#0 default::main]
000000: E2 30       sep #$30
000002: 64 11       stz $11
000004: 64 10       stz $10
000006: A9 01       lda #$01
000008: 48          pha
000009: A9 00       lda #$00
00000B: 85 12       sta $12
00000D: AA          tax
00000E: 60          rts
