var dst1 = 0x10
var dst2 = 0x11
var dst3 = 0x12

func main {
    // A is killed by the following load, so the zero load is dead and the
    // store run can become STZ.
    dst1 = dst2 = a = 0
    a = 1
    // `pha` keeps `a = 1` observable across the next `dst3 = a = 0`,
    // otherwise the new dead-register pass would also drop it.
    pha

    // A is used by the transfer, so keep the visible LDA/STA data flow.
    dst3 = a = 0
    x = a

    return
}
