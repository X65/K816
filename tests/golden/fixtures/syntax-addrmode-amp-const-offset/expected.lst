[default]
000000: E2 30 A2 02 B5 02 B9 00 00 BD 01 00 B5 03 B5 03
000010: B5 02 60


[disasm obj#0 default::main]
000000: E2 30       sep #$30
000002: A2 02       ldx #$02
000004: B5 02       lda $02,X
000006: B9 00 00    lda $0000,Y
000009: BD 01 00    lda $0001,X
00000C: B5 03       lda $03,X
00000E: B5 03       lda $03,X
000010: B5 02       lda $02,X
000012: 60          rts
