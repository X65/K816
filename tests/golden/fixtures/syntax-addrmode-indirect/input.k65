func shell_tokenize_buffer @a16 @i8 {
    sta shell_str_ptr
    ldx #0                  // token index
    ldy #0                  // in-token flag

    @a8
shell_tokenize_loop:
    @a16 {
        inc shell_str_ptr       // move to next character
    }
    lda (shell_str_ptr)
    == goto shell_tokenize_exit // found nul-terminator - exit
}
