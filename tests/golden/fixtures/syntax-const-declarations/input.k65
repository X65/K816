const BASE = 0x200
const A = 1, B = 2
const OFFSET = BASE + B
var ptr = OFFSET
var arr[A + B]

func main @a8 @i8 {
    // `pha` between adjacent immediates keeps each load observable so
    // the optimizer cannot fold them, preserving this fixture's
    // verification of every constant value.
    lda #A
    pha
    lda #B
    lda ptr
    lda arr
}
