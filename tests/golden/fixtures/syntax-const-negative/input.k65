const A = -1, B, C
const X = -3, Y = 2, Z

const NEG = -5

func main @a8 {
    // `pha` between immediates keeps each load observable so the
    // optimizer cannot fold them, preserving this fixture's
    // verification of every negative-constant value.
    lda #A
    pha
    lda #B
    pha
    lda #C
    pha

    lda #X
    pha
    lda #Y
    pha
    lda #Z
    pha

    @a16
    lda #A
    pha
    lda #X
    pha
    lda #NEG
}
