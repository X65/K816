const A = 0, B, C
const X, Y, Z
const BASE = 10
const P = BASE, Q, R
const M = 0, N, O = 10, P2

var ptr_a = C
var ptr_b = Z
var ptr_c = R
var ptr_d = P2

func main {
    // `pha` between immediates keeps each load observable so the
    // optimizer cannot fold them, preserving this fixture's
    // verification of every constant value in the sequence.
    lda #A
    pha
    lda #B
    pha
    lda #C
    pha

    lda #X
    pha
    lda #Y
    pha
    lda #Z
    pha

    lda #P
    pha
    lda #Q
    pha
    lda #R
    pha

    lda #M
    pha
    lda #N
    pha
    lda #O
    pha
    lda #P2

    lda ptr_a
    lda ptr_b
    lda ptr_c
    lda ptr_d
}
