// Exit-width contract variants:
// - checked bare call adopts the callee's inferred exit mode for later bridges
// - unchecked `call foo` restores the caller mode

func widen @a8 () -> @a16 {
    @a16
    nop
}

func wide_user @a16 {
    lda #$1234
}

func main {
    widen
    wide_user
    call widen
    wide_user
}
