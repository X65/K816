[disasm obj#0 default::main]
000000: E2 30       sep #$30
000002: A7 20       lda [$20]
000004: B7 20       lda [$20],Y
000006: 87 20       sta [$20]
000008: 97 20       sta [$20],Y
00000A: A3 04       lda $04,S
