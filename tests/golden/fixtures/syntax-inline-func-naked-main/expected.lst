[default]
000000: E2 10 E8 DA 60 E2 10 E8 4C 00 00 E2 30 20 00 00
000010: 4C 05 00


[disasm obj#0 default::normal]
000000: E2 10       sep #$10
000002: E8          inx
000003: DA          phx
000004: 60          rts

[disasm obj#0 default::no_auto_rts]
000005: E2 10       sep #$10
000007: E8          inx
000008: 4C 00 00    jmp $0000

[disasm obj#0 default::main]
00000B: E2 30       sep #$30
00000D: 20 00 00    jsr $0000
000010: 4C 05 00    jmp $0005
