// Two `jmp` edges into `target` arrive in different MX modes.
// `target` has no `@a*/@i*` annotation, so the diagnostic uses the
// no-declared-mode form (two edge spans, symmetric help).
func target {
    rts
}

func source @a16 @i16 {
    cmp #1
    bne .skip
    jmp target
    .skip:
    @a8
    jmp target
}
