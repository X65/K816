// STA/STZ/TRB/TSB are accumulator-width sensitive (M flag).
// Even with memory operands (encoding unchanged by width), mode ops must be preserved.

var zp = 0x20

func main {
    @a16
    stz zp
    lda #$1234
    sta zp
    trb zp
    tsb zp

    @a8
    stz zp
    lda #$12
    sta zp
    trb zp
    tsb zp
}
