[default]
000000: E2 30 AD 00 20 C2 20 AD 00 20 8D 00 20 E2 20 AD
000010: 00 20 8D 00 20 60


[disasm obj#0 default::main]
000000: E2 30       sep #$30
000002: AD 00 20    lda $2000
000005: C2 20       rep #$20
000007: AD 00 20    lda $2000
00000A: 8D 00 20    sta $2000
00000D: E2 20       sep #$20
00000F: AD 00 20    lda $2000
000012: 8D 00 20    sta $2000
000015: 60          rts
