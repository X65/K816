[default]
000000: E2 30 16 40 56 40 36 40 76 40 F6 40 D6 40 60


[disasm obj#0 default::main]
000000: E2 30       sep #$30
000002: 16 40       asl $40,X
000004: 56 40       lsr $40,X
000006: 36 40       rol $40,X
000008: 76 40       ror $40,X
00000A: F6 40       inc $40,X
00000C: D6 40       dec $40,X
00000E: 60          rts
