[default]
000000: E2 30 B2 20 A1 20 B1 20 92 20 81 20 91 20 60


[disasm obj#0 default::main]
000000: E2 30       sep #$30
000002: B2 20       lda ($20)
000004: A1 20       lda ($20,X)
000006: B1 20       lda ($20),Y
000008: 92 20       sta ($20)
00000A: 81 20       sta ($20,X)
00000C: 91 20       sta ($20),Y
00000E: 60          rts
