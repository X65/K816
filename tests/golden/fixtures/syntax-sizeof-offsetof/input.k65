var TASKS[
    .sp         :word
    .state      :byte
    .signals    :byte
    .sigmask    :byte
    .evtmask    :byte
    .sighndl    :word
    .message[
        .from   :byte
        .type   :byte
        .data   :far
    ]
] = $4000

var counter:word = $80
var buffer[32] = $0100

var POS[
    .x :byte
    .y :byte
] * 32 = $5000

func main @a8 @i8 {
    // `pha` between immediates keeps each load observable so the
    // optimizer cannot fold them, preserving this fixture's
    // verification of every :sizeof / :offsetof value.

    // :sizeof on aggregate var
    lda #TASKS:sizeof           // 13 bytes total
    pha

    // :sizeof on fields
    lda #TASKS.state:sizeof     // 1 (byte)
    pha
    lda #TASKS.sp:sizeof        // 2 (word)
    pha
    lda #TASKS.message:sizeof   // 5 (composite: 1+1+3)
    pha
    lda #TASKS.message.data:sizeof // 3 (far)
    pha

    // :sizeof on plain vars
    lda #counter:sizeof         // 2 (word)
    pha
    lda #buffer:sizeof          // 32
    pha

    // :offsetof on fields
    lda #TASKS.state:offsetof   // 2 (after .sp:word)
    pha
    lda #TASKS.sp:offsetof      // 0 (first field)
    pha
    lda #TASKS.signals:offsetof // 3
    pha
    lda #TASKS.sighndl:offsetof // 6
    pha

    // :offsetof on nested fields
    lda #TASKS.message.from:offsetof  // 8 (after sighndl:word at offset 6..8)
    pha
    lda #TASKS.message.data:offsetof  // 10
    pha

    // :offsetof on composite field
    lda #TASKS.message:offsetof  // 8
    pha

    // :sizeof in arithmetic expression
    lda #TASKS:sizeof + 1       // 14
    pha

    // :sizeof with var count combined
    lda #POS:sizeof             // 2 (base element: .x:byte + .y:byte)
    pha
    lda #POS.y:offsetof         // 1 (y is the second byte in the struct)
}
