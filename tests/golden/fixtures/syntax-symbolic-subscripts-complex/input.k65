const CGIA_PLANES = 4
const CGIA_PLANE_REGS_NO = 8

var CGIA[
    .mode :byte

    .bckgnd_bank :byte
    .sprite_bank :byte
    ._ctl_reserved :byte [16 - 3]
    // -------------------------------------------------------------------
    .raster :word
    ._rst_reserved1 :byte [8 - 2]

    .int_raster :word // Line to generate raster interrupt.
    .int_enable :byte  // Interrupt flags. [VBI DLI RSI x x x x x]
    .int_status :byte  // Interrupt flags. [VBI DLI RSI x x x x x]
    ._rst_reserved2 :byte [8 - 4]
    // -------------------------------------------------------------------
    ._reserved :byte [16]
    // -------------------------------------------------------------------
    .planes :byte // [TTTTEEEE] EEEE - enable bits, TTTT - type (0 bckgnd, 1 sprite)
    .order :byte  // plane order permutation - SJT ordering
    ._pln_reserved1 :byte [4 - 2]

    .back_color :byte
    ._pln_reserved :byte [4 - 1]

    .offset :word [CGIA_PLANES] // DisplayList or SpriteDescriptor table start
    // -------------------------------------------------------------------
    .plane_regs :byte [CGIA_PLANES * CGIA_PLANE_REGS_NO]
] = $FF00

func main @a8 {
    lda CGIA.mode
    sta CGIA.plane_regs[0]
    @a16
    lda CGIA.offset[3]
}
