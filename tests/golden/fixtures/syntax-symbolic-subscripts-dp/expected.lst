[DP]
    $00..$03: gpio
    $00: gpio.ddr (alias)
    $01: gpio.data (alias)
    $02: gpio.latch (alias)


[default]
000200: E2 30 A5 00 85 01 C2 20 A5 02 60


[disasm obj#0 default::main]
000200: E2 30       sep #$30
000202: A5 00       lda $00
000204: 85 01       sta $01
000206: C2 20       rep #$20
000208: A5 02       lda $02
00020A: 60          rts
