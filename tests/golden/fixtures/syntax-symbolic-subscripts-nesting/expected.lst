[default]
000000: C2 10 E2 20 AD 00 40 BD 02 40 AD 08 40 AC 0A 40
000010: AD 0A 40 60


[disasm obj#0 default::main]
000000: C2 10       rep #$10
000002: E2 20       sep #$20
000004: AD 00 40    lda $4000
000007: BD 02 40    lda $4002,X
00000A: AD 08 40    lda $4008
00000D: AC 0A 40    ldy $400A
000010: AD 0A 40    lda $400A
000013: 60          rts
