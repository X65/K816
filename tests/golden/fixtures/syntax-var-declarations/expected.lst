[default]
000000: 00 00 00 00 00 00 00 00 00 00 00 E2 30 AD 00 02
000010: AD 00 00 AD 04 00 AD 08 00 AD 00 03 60


[disasm obj#0 default::main]
00000B: E2 30       sep #$30
00000D: AD 00 02    lda $0200
000010: AD 00 00    lda $0000
000013: AD 04 00    lda $0004
000016: AD 08 00    lda $0008
000019: AD 00 03    lda $0300
00001C: 60          rts
