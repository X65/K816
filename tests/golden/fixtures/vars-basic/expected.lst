[default]
000000: 00 EA 60 E2 30 AD 00 00 AD 34 12 AD 01 00 60


[disasm obj#0 default::target]
000001: EA          nop
000002: 60          rts

[disasm obj#0 default::main]
000003: E2 30       sep #$30
000005: AD 00 00    lda $0000
000008: AD 34 12    lda $1234
00000B: AD 01 00    lda $0001
00000E: 60          rts
